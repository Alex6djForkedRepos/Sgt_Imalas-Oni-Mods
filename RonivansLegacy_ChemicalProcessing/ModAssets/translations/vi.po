msgstr "<link=\"SPACERWINDOWLARGE\">Cửa sổ không gian lớn</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.DESC"
msgid "A small sized spacer window.."
msgstr "Một cửa sổ không gian kích thước nhỏ."


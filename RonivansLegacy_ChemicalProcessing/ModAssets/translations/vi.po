msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDING.STATUSITEMS.ALGAEGROWER_LIGHTEFFICIENCY.NAME"
msgid "Growth Efficiency: {0}"
msgstr "Hiệu suất Tăng trưởng: {0}"


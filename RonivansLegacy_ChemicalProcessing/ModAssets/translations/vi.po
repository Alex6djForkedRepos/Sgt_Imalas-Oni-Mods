msgstr "Một lỗ thông áp suất cao định kỳ phun trào <link=\"NITROGENGAS\">Khí Nitơ</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.NITROGENVENT.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.NITROGENVENT.NAME"
msgid "<link=\"GEYSERGENERICNITROGENVENT\">Nitrogen Vent</link>"
msgstr "<link=\"GEYSERGENERICNITROGENVENT\">Mạch phun khí Nitơ</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.PHOSPHORUSGEYSER.DESC

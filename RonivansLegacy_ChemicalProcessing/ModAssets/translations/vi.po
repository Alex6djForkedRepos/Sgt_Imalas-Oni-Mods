#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.FACADES.SPACERWINDOW_B.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.FACADES.SPACERWINDOW_B.DESC"
msgid "A small sized spacer window. This is the B model."
msgstr ""
"Một cửa sổ không gian kích thước nhỏ. \n"
"\n"
"Đây là mẫu B."

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.FACADES.SPACERWINDOW_B.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.FACADES.SPACERWINDOW_B.NAME"
msgid "<link=\"SPACERWINDOWB\">Spacer Window Alt.</link>"
msgstr "<link=\"SPACERWINDOWB\">Cửa sổ không gian B</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWINDOWWALL.NAME"

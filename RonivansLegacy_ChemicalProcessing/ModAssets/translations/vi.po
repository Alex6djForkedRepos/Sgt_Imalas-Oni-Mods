#. RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWALL.FACADES.SPACERPANEL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.BUILDINGS.PREFABS.SPACERWALL.FACADES.SPACERPANEL.DESC"
msgid "A small sized spacer panel."
msgstr "Một tấm ốp không gian kích thước nhỏ."


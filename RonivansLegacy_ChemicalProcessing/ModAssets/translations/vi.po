msgstr "<link=\"GEYSERGENERICAMMONIUMWATERGEYSER\">Mạch dung dịch Amoniac</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.HOTMERCURYGASVENT.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.HOTMERCURYGASVENT.DESC"
msgid "A highly pressurized geothermal vent that periodically erupts with hot <link=\"MERCURYGAS\">Mercury Gas</link>."
msgstr "Một lỗ thông địa nhiệt áp suất cao định kỳ phun trào <link=\"MERCURYGAS\">Khí thủy ngân</link> nóng."

#. RonivansLegacy_ChemicalProcessing.STRINGS.CREATURES.SPECIES.GEYSER.HOTMERCURYGASVENT.NAME

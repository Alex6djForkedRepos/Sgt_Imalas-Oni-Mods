#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.MINING_DRILLBITS_TUNGSTEN_ITEM.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.MINING_DRILLBITS_TUNGSTEN_ITEM.DESC"
msgid ""
"A set of sturdy drill bits made for extremely hard rock mining operations.\n"
"Has no own guidance system and can drill through deep, very hard rocks stratum even at high temperature."
msgstr ""
"Một bộ mũi khoan chắc chắn được chế tạo cho các hoạt động khai thác đá cực cứng.\n"
"\n"
"Không có hệ thống dẫn đường riêng và có thể khoan xuyên qua các tầng đá rất cứng và sâu ngay cả ở nhiệt độ cao."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.MINING_DRILLBITS_TUNGSTEN_ITEM.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.MINING_DRILLBITS_TUNGSTEN_ITEM.NAME"
msgid "<link=\"MININGDRILLBITSTUNGSTENITEM\">Tungsten Drillbits</link>"
msgstr "<link=\"MININGDRILLBITSTUNGSTENITEM\">Mũi khoan Vonfram</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.MINING_DRILLBITS_TUNGSTEN_ITEM.RECIPE_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INDUSTRIAL_PRODUCTS.MINING_DRILLBITS_TUNGSTEN_ITEM.RECIPE_DESC"
msgid "Instruct the computer to produce Tungsten Drillbits."
msgstr "Ra lệnh cho máy tính sản xuất Mũi khoan Vonfram."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.DESC"
msgid "Rayon is a synthetic fiber, chemically made from plant based regenerated cellulose."
msgstr "Rayon là một loại sợi tổng hợp, được sản xuất hóa học từ xenluloza tái sinh có nguồn gốc thực vật."

#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.NAME"
msgid "<link=\"RAYONFIBER\">Rayon Fiber</link>"
msgstr "<link=\"RAYONFIBER\">Sợi Rayon</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.NAME_PLURAL
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.NAME_PLURAL"
msgid "<link=\"RAYONFIBER\">Rayon Fibers</link>"
msgstr "<link=\"RAYONFIBER\">Sợi Rayon</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.RECIPE_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.ITEMS.INGREDIENTS.RAYONFIBER.RECIPE_DESC"
msgid "Produces <link=\"RAYONFIBER\">Rayon Fibers</link> from the pulp of {0}."
msgstr "Sản xuất <link=\"RAYONFIBER\">Sợi Rayon</link> từ bột của {0}."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.CODEXINFO.COMBINED_RECIPE_TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.CODEXINFO.COMBINED_RECIPE_TOOLTIP"
msgid "This recipe ingredient requirement can be satisfied by any of the following items:"
msgstr "Yêu cầu nguyên liệu cho công thức này có thể được đáp ứng bởi bất kỳ vật phẩm nào sau đây:"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_BIOFUEL
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_BIOFUEL"
msgid "<link=\"AIOBIOFUEL\">Renewable Biofuel</link>"
msgstr "<link=\"AIOBIOFUEL\">Nhiên liệu sinh học tái tạo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_BIOFUEL_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_BIOFUEL_DESC"
msgid "Combustible liquid fuels made frome regenerative materials."
msgstr "Các loại nhiên liệu lỏng dễ cháy được tạo ra từ các vật liệu có khả năng tái tạo."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_CARRIERGAS
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_CARRIERGAS"
msgid "<link=\"AIOCARRIERGAS\">Carrier Gas</link>"
msgstr "<link=\"AIOCARRIERGAS\">Khí mang</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_CARRIERGAS_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_CARRIERGAS_DESC"
msgid "Carrier Gases are inert or semi-inert gases that are used in plasma related processes."
msgstr "Khí mang là các loại khí trơ hoặc bán trơ được sử dụng trong các quy trình liên quan đến plasma."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_HARDENEDALLOY
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_HARDENEDALLOY"
msgid "<link=\"AIOHARDENEDALLOY\">Hardened Alloy</link>"
msgstr "<link=\"AIOHARDENEDALLOY\">Hợp kim gia cường</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_HARDENEDALLOY_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_HARDENEDALLOY_DESC"
msgid ""
"Hardened Alloys are a fusion of two or more materials.\n"
"Their high material strength allows them to be used as a substitute to <link=\"STEEL\">Thép</link>."
msgstr ""
"Hợp kim gia cường là sự kết hợp của hai hoặc nhiều loại vật liệu.\n"
"\n"
"Độ bền vật liệu cao cho phép chúng được sử dụng để thay thế cho <link=\"STEEL\">Thép</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_RADEMITTERINPUTMATERIAL
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_RADEMITTERINPUTMATERIAL"
msgid "Radioactive Material"
msgstr "Vật liệu phóng xạ"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_RADEMITTERINPUTMATERIAL_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.AIO_RADEMITTERINPUTMATERIAL_DESC"
msgid "Radioactive Material that can be used to fuel the Rad Projector."
msgstr "Vật liệu phóng xạ có thể được sử dụng làm nhiên liệu cho Máy chiếu Bức xạ."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.CHEMICALPROCESSING_RANDOMSAND
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.CHEMICALPROCESSING_RANDOMSAND"
msgid "<link=\"CHEMICALPROCESSINGRANDOMSAND\">Metallic Sand</link>"
msgstr "<link=\"CHEMICALPROCESSINGRANDOMSAND\">Cát kim loại</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.CHEMICALPROCESSING_RANDOMSAND_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.CHEMICALPROCESSING_RANDOMSAND_DESC"
msgid "Sandy materials composed of a various number of metallic grains"
msgstr "Vật liệu dạng cát bao gồm nhiều hạt kim loại khác nhau."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_DRILLBIT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_DRILLBIT"
msgid "<link=\"MINERALPROCESSINGDRILLBIT\">Drillbit</link>"
msgstr "<link=\"MINERALPROCESSINGDRILLBIT\">Mũi khoan</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_DRILLBIT_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_DRILLBIT_DESC"
msgid "Drillbits that are used by the Asteroid Drills to extract resources from otherwise unreachable sectors of the asteroid."
msgstr "Các mũi khoan được Máy khoan Tiểu hành tinh sử dụng để khai thác tài nguyên từ những khu vực khó tiếp cận trên tiểu hành tinh."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_GUIDANCEUNIT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_GUIDANCEUNIT"
msgid "<link=\"MINERALPROCESSINGGUIDANCEUNIT\">Guidance Device</link>"
msgstr "<link=\"MINERALPROCESSINGGUIDANCEUNIT\">Thiết bị dẫn đường</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_GUIDANCEUNIT_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.MINERALPROCESSING_GUIDANCEUNIT_DESC"
msgid "Guidance Devices allow the the mining drillhead to be programmed to target mine specific asteroid sectors."
msgstr "Thiết bị dẫn đường cho phép đầu khoan khai thác được lập trình để nhắm mục tiêu khai thác các khu vực tiểu hành tinh cụ thể."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.RANDOMRECIPEINGREDIENT_DESTROYONCANCEL
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.RANDOMRECIPEINGREDIENT_DESTROYONCANCEL"
msgid "<link=\"RANDOMRECIPEINGREDIENTDESTROYONCANCEL\">Non-refundable Ingredient</link>"
msgstr "<link=\"RANDOMRECIPEINGREDIENTDESTROYONCANCEL\">Nguyên liệu không hoàn lại</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.RANDOMRECIPEINGREDIENT_DESTROYONCANCEL_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.RANDOMRECIPEINGREDIENT_DESTROYONCANCEL_DESC"
msgid "This ingredient gets used up during its use, if a recipe with it gets canceled, it is lost."
msgstr "Nguyên liệu này bị tiêu hao trong quá trình sử dụng; nếu công thức sử dụng nó bị hủy, nguyên liệu này sẽ mất."

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.SODAFOUNTAINGAS
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.SODAFOUNTAINGAS"
msgid "<link=\"SODAFOUNTAINGAS\">Soda Gas</link>"
msgstr "<link=\"SODAFOUNTAINGAS\">Khí Soda</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.SODAFOUNTAINGAS_DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.MISC.TAGS.SODAFOUNTAINGAS_DESC"
msgid "Gasses that can be used by the <link=\"SODAFOUNTAIN\">Soda Fountain</link> to create a sparkling soda."
msgstr "Các loại khí có thể được sử dụng bởi <link=\"SODAFOUNTAIN\">Máy pha Soda</link> để tạo ra soda có ga."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.BIOCHEMISTRY_RENEWABLEFUEL.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.BIOCHEMISTRY_RENEWABLEFUEL.DESC"
msgid "A new generation of renewable fuels that can be produced from organic matter."
msgstr "Một thế hệ nhiên liệu tái tạo mới có thể được sản xuất từ chất hữu cơ."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.BIOCHEMISTRY_RENEWABLEFUEL.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.BIOCHEMISTRY_RENEWABLEFUEL.NAME"
msgid "<link=\"BIOCHEMISTRYRENEWABLEFUEL\">Renewable Combustion Fuels</link>"
msgstr "<link=\"BIOCHEMISTRYRENEWABLEFUEL\">Nhiên liệu đốt tái tạo</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.HPA_RAILS_RESEARCH.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.HPA_RAILS_RESEARCH.DESC"
msgid "Vastly increase your ability to transport large amounts of solid materials on rails"
msgstr "Tăng đáng kể khả năng vận chuyển số lượng lớn vật liệu rắn trên đường ray."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.HPA_RAILS_RESEARCH.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.HPA_RAILS_RESEARCH.NAME"
msgid "<link=\"HPARAILSRESEARCH\">High-Capacity Solid Transport</link>"
msgstr "<link=\"HPARAILSRESEARCH\">Vận chuyển vật liệu rắn khối lượng lớn</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.METALLURGY_PLASMABASEDREFINEMENTTECH.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.METALLURGY_PLASMABASEDREFINEMENTTECH.DESC"
msgid "Unlocks new high energy plasma based based refinement processes."
msgstr "Mở khóa các quy trình tinh chế mới dựa trên plasma năng lượng cao."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.METALLURGY_PLASMABASEDREFINEMENTTECH.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.METALLURGY_PLASMABASEDREFINEMENTTECH.NAME"
msgid "<link=\"METALLURGYPLASMABASEDREFINEMENTTECH\">High Energy Plasma Refinement</link>"
msgstr "<link=\"METALLURGYPLASMABASEDREFINEMENTTECH\">Tinh chế Plasma năng lượng cao</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_MK2DRILLTECH.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_MK2DRILLTECH.DESC"
msgid "Unlocks the ability to drill into previously unreachable layers of the asteroid for resource extraction."
msgstr "Mở khóa khả năng khoan vào các lớp trước đây không thể tiếp cận của tiểu hành tinh để khai thác tài nguyên."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_MK2DRILLTECH.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_MK2DRILLTECH.NAME"
msgid "<link=\"MININGMK2DRILLTECH\">Deep Core Mining</link>"
msgstr "<link=\"MININGMK2DRILLTECH\">Khai thác lõi sâu</link>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.DESC
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.DESC"
msgid "Enables fabrication of <style=\"KKeyword\">Simple Drillbits</style> at the <link=\"CRAFTINGTABLE\">Bàn chế đồ dùng</link>"
msgstr "Cho phép chế tạo <style=\"KKeyword\">Mũi khoan cơ bản</style> tại <link=\"CRAFTINGTABLE\">Bàn chế tạo</link>."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RESEARCH.TECHS.MINING_SIMPLEDRILLBIT_CRAFTING.NAME"
msgid "<style=\"KKeyword\">Simple Drillbit</style> Pattern"
msgstr "Bản thiết kế <style=\"KKeyword\">Mũi khoan cơ bản</style>"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.NAME"
msgid "Anaerobic Digester Natgas Multiplier"
msgstr "Hệ số nhân khí tự nhiên của Máy phân hủy kỵ khí"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_ANAEROBICDIGESTERBUFF.TOOLTIP"
msgid "Multiply the natural gas output amounts of the anaerobic digester by this value."
msgstr "Nhân lượng khí tự nhiên đầu ra của Máy phân hủy kỵ khí với giá trị này."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.NAME"
msgid "Expeller Press Oil Multiplier"
msgstr "Hệ số nhân dầu của Máy ép"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILMULTIPLIER.TOOLTIP"
msgid "Multiply the vegetable oil output amounts of the expeller press by this value."
msgstr "Nhân lượng dầu thực vật đầu ra của Máy ép với giá trị này."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.NAME"
msgid "Expeller Press Rebalance"
msgstr "Tái cân bằng Máy ép"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BIOCHEM_OILPRESSREBALANCE.TOOLTIP"
msgid ""
"Rebalances the yield of the Expeller Press Recipes to yield larger amounts of oil and biomass.\n"
"This give the building a better purpose, as its current yields are quite low, compared to the seakomb, which has its balance defined by the game.\n"
"Turn off to get the old yields back"
msgstr ""
"Tái cân bằng sản lượng của các công thức Máy ép để thu được lượng dầu và sinh khối lớn hơn.\n"
"\n"
"Điều này giúp công trình có mục đích sử dụng tốt hơn, vì sản lượng hiện tại khá thấp so với seakomb, vốn đã có sự cân bằng mặc định từ trò chơi.\n"
"\n"
"Tắt để khôi phục sản lượng cũ."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME"
msgid "Open Building Configuration Editor"
msgstr "Mở Trình chỉnh sửa cấu hình công trình"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME_ALT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.NAME_ALT"
msgid "Configure Mod Buildings"
msgstr "Cấu hình công trình Mod"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.BUILDINGEDITOR.TOOLTIP"
msgid ""
"Open the building editor to individually toggle all buildings added by the mod and change settings on some.\n"
"All changes done here require a restart!"
msgstr ""
"Mở trình chỉnh sửa công trình để bật/tắt riêng lẻ tất cả các công trình được thêm bởi mod và thay đổi cài đặt của chúng.\n"
"\n"
"Tất cả các thay đổi thực hiện ở đây đều yêu cầu khởi động lại game!"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.FORMAT
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.FORMAT"
msgid "0 MJ"
msgstr ""

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.NAME"
msgid "Arc Furnace Thermal Capacitor Size"
msgstr "Dung lượng tụ nhiệt Lò hồ quang"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARC_CAPACITOR.TOOLTIP"
msgid "The total heat capacity of the arc-furnace's internal thermal capacitor"
msgstr "Tổng dung lượng nhiệt của tụ nhiệt bên trong Lò hồ quang."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.NAME"
msgid "Arc Furnace Thermal Fudge"
msgstr "Hệ số hiệu chỉnh nhiệt Lò hồ quang"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_ARCFUDGE.TOOLTIP"
msgid ""
"The selective arc furnace only puts a percentage of its recipes heat into its internal heat capacitor.\n"
"The default value for the mod is 90%"
msgstr ""
"Lò hồ quang chọn lọc chỉ chuyển một phần trăm nhiệt lượng từ các công thức của nó vào tụ nhiệt bên trong.\n"
"\n"
"Giá trị mặc định cho mod là 90%."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.NAME"
msgid "Metal Refinery Thermal Fudge"
msgstr "Hệ số hiệu chỉnh nhiệt Lò tinh luyện kim loại"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGE.TOOLTIP"
msgid ""
"The Metal refinery only puts a percentage of its recipes heat into the coolant.\n"
"The vanilla value for this is 80%.\n"
"The default value for the mod is 60%"
msgstr ""
"Lò tinh luyện kim loại chỉ chuyển một phần trăm nhiệt lượng từ các công thức của nó vào chất làm mát.\n"
"Giá trị gốc của trò chơi là 80%.\n"
"Giá trị mặc định cho mod là 60%."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.NAME"
msgid "Advanced Refinery Thermal Fudge"
msgstr "Hệ số hiệu chỉnh nhiệt Lò tinh luyện nâng cao"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CHEMPROC_REFINERYFUDGEADV.TOOLTIP"
msgid ""
"The Advanced Metal refinery only puts a percentage of its recipes heat into the coolant.\n"
"The default value for the mod is 90%"
msgstr ""
"Lò tinh luyện kim loại nâng cao chỉ chuyển một phần trăm nhiệt lượng từ các công thức của nó vào chất làm mát.\n"
"\n"
"Giá trị mặc định cho mod là 90%."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.NAME"
msgid "Move all Reservoirs to their piping category"
msgstr "Di chuyển tất cả các Bể chứa sang danh mục đường ống tương ứng"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.CUSTOMRES_MOVETOCONDUITCATEGORY.TOOLTIP"
msgid ""
"Moves all vanilla and mod reservoirs into the respective piping category:\n"
"Liquid Reservoirs are found under \"Plumbing\"\n"
"Gas Reservoirs are found under\"Ventilation\""
msgstr ""
"Di chuyển tất cả các bể chứa gốc (vanilla) và bể chứa từ mod vào danh mục đường ống tương ứng:\n"
"\n"
"Bể chứa chất lỏng được tìm thấy trong mục \"Đường ống\" (Plumbing).\n"
"\n"
"Bể chứa khí được tìm thấy trong mục \"Thông gió\" (Ventilation)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.NAME"
msgid "All Walls hide pipes"
msgstr "Tất cả các bức tường đều ẩn đường ống"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.DRYWALL_HIDES_PIPES.TOOLTIP"
msgid "Like with the mod \"Drywall hides Pipes\", all backwall buildings are rendered in front of pipes and wires."
msgstr "Giống như bản mod \"Drywall hides Pipes\", tất cả các công trình tường nền sẽ được hiển thị ở phía trước các đường ống và dây dẫn."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.NAME"
msgid "Enable Mod Content"
msgstr "Kích hoạt nội dung của Mod"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP"
msgid ""
"The mod is enabled, this includes buildings, research, recipes and other mod specific mechanics.\n"
"You can still disable individual buildings of the mod in the building configuration editor, separate from this setting."
msgstr ""
"Mod đang được bật, bao gồm các công trình, nghiên cứu, công thức và các cơ chế đặc trưng khác của mod.\n"
"\n"
"Bạn vẫn có thể tắt riêng lẻ từng công trình của mod trong trình chỉnh sửa cấu hình công trình, độc lập với cài đặt này."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP_ELEMENTS
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.ENABLEMOD.TOOLTIP_ELEMENTS"
msgid ""
"The mod is enabled, this includes buildings, research, recipes, elements, comets and other mod specific mechanics.\n"
"You can still disable individual buildings of the mod in the building editor, separate from this setting.\n"
"Warning: when this mod is enabled, worldgen will be altered by new elements"
msgstr ""
"Mod đang được bật, bao gồm các công trình, nghiên cứu, công thức, nguyên tố, sao chổi và các cơ chế đặc trưng khác của mod.\n"
"\n"
"Bạn vẫn có thể tắt riêng lẻ từng công trình của mod trong trình chỉnh sửa công trình, độc lập với cài đặt này.\n"
"\n"
"Cảnh báo: Khi mod này được bật, quá trình khởi tạo thế giới (worldgen) sẽ bị thay đổi bởi các nguyên tố mới."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.NAME"
msgid "Mod Geysers spawn from worldgen"
msgstr "Mạch của Mod xuất hiện khi khởi tạo thế giới"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.GEYSERS.TOOLTIP"
msgid ""
"New Geysers are added to the pool of randomly spawned geysers.\n"
"This will affect worldgen if active (different random geysers are chosen compared to vanilla)\n"
"Turning it off will prevent those geysers from showing up from worldgen naturally unless you use a different mod to add them manually (e.g. customize geyser or CGM)\n"
"\n"
"Revealing a random geyser (those spawned on classic asteroids and by the geoactive trait) in an already existing world WILL be affected by this, turn off this option if you don't want existing saves to be affected."
msgstr ""
"Các Mạch mới sẽ được thêm vào danh sách mạch nước xuất hiện ngẫu nhiên.\n"
"\n"
"Điều này sẽ ảnh hưởng đến quá trình khởi tạo thế giới nếu được kích hoạt (các mạch nước ngẫu nhiên khác sẽ được chọn so với phiên bản gốc của trò chơi).\n"
"\n"
"Tắt tùy chọn này sẽ ngăn các mạch nước đó xuất hiện tự nhiên khi khởi tạo thế giới, trừ khi bạn sử dụng một bản mod khác để thêm chúng thủ công (ví dụ: Customize Geyser hoặc CGM).\n"
"\n"
"Việc làm lộ diện một mạch nước ngẫu nhiên (những mạch nước xuất hiện trên các tiểu hành tinh cổ điển và bởi đặc tính hoạt động địa chất - geoactive) trong một thế giới đã tồn tại SẼ bị ảnh hưởng bởi tùy chọn này; hãy tắt tùy chọn này nếu bạn không muốn các tệp lưu game hiện tại bị ảnh hưởng."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.NAME"
msgid "High Pressure Gas Capacity Multiplier"
msgstr "Hệ số nhân dung tích Khí áp suất cao"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_CAPACITY.TOOLTIP"
msgid ""
"High pressure gas pipes allow pumping gases at much higher pipe throughput than regular pipes, at the cost of more expensive building materials.\n"
"Total Capacity is calculated based on the base pipe capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Đường ống dẫn khí áp suất cao cho phép bơm khí với lưu lượng đường ống lớn hơn nhiều so với ống thông thường, với chi phí nguyên liệu xây dựng đắt hơn.\n"
"\n"
"Tổng dung tích được tính toán dựa trên dung tích ống cơ bản (bao gồm khả năng tương thích với CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.NAME"
msgid "Base Wattage: High Pressure Gas Pump"
msgstr "Công suất cơ bản: Máy bơm khí áp suất cao"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_GAS_PUMPCOST.TOOLTIP"
msgid "The total pump wattage is calculated by multiplying the base wattage value with the respective pipe capacity multiplier (compared to regular pipes)"
msgstr "Tổng công suất máy bơm được tính bằng cách nhân giá trị công suất cơ bản với hệ số nhân dung tích đường ống tương ứng (so với đường ống thông thường)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.NAME"
msgid "High Pressure Liquid Capacity Multiplier"
msgstr "Hệ số nhân dung tích chất lỏng áp suất cao"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_CAPACITY.TOOLTIP"
msgid ""
"High pressure liquid pipes allow pumping liquids at much higher pipe throughput than regular pipes, at the cost of more expensive building materials.\n"
"Total Capacity is calculated based on the base pipe capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Đường ống chất lỏng áp suất cao cho phép bơm chất lỏng với lưu lượng lớn hơn nhiều so với đường ống thông thường, đổi lại chi phí nguyên liệu xây dựng đắt đỏ hơn.\n"
"Tổng dung tích được tính dựa trên dung tích đường ống cơ bản (bao gồm khả năng tương thích với CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.NAME"
msgid "Base Wattage: High Pressure Liquid Pump"
msgstr "Công suất cơ bản: Máy bơm chất lỏng áp suất cao"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_LIQUID_PUMPCOST.TOOLTIP"
msgid "The total pump wattage is calculated by multiplying the base wattage value with the respective pipe capacity multiplier (compared to regular pipes)"
msgstr "Tổng công suất máy bơm được tính bằng cách nhân giá trị công suất cơ bản với hệ số nhân dung tích đường ống tương ứng (so với đường ống thông thường)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.NAME"
msgid "Heavy-Duty Auto-Sweeper Range"
msgstr "Phạm vi của Máy quét tự động hạng nặng"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ARMRANGE.TOOLTIP"
msgid "The Heavy-Duty Auto-Sweeper serves as a late game version of the autosweeper, having higher range and throughput at the cost of more complex build requirements"
msgstr "Máy quét tự động hạng nặng (Heavy-Duty Auto-Sweeper) đóng vai trò là phiên bản cuối game của máy quét tự động, có phạm vi và lưu lượng cao hơn nhưng yêu cầu chế tạo phức tạp hơn."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.NAME"
msgid "Heavy-Duty Rail Capacity Multiplier"
msgstr "Phạm vi của Máy quét tự động hạng nặng"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_CAPACITY.TOOLTIP"
msgid ""
"Heavy-Duty Rails serve as an late game upgrade to conveyor rails, having a much higher throughput at the cost of more complex build requirements.\n"
"Total Capacity is calculated based on the base rail capacity (includes compatibility with CustomizeBuildings)"
msgstr "Máy quét tự động hạng nặng (Heavy-Duty Auto-Sweeper) đóng vai trò là phiên bản cuối game của máy quét tự động, có phạm vi và lưu lượng cao hơn nhưng yêu cầu chế tạo phức tạp hơn."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.NAME"
msgid "Enable Heavy-Duty Rails"
msgstr "Kích hoạt đường ray hạng nặng"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_ENABLE.TOOLTIP"
msgid "Heavy-Duty Rails serve as an late game upgrade to conveyor rails, having a much higher throughput at the cost of more complex build requirements."
msgstr "Đường ray hạng nặng đóng vai trò là bản nâng cấp cuối game cho đường ray băng chuyền, có lưu lượng cao hơn nhiều nhưng yêu cầu chế tạo phức tạp hơn."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.NAME"
msgid "Insulated Heavy-Duty Rails"
msgstr "Đường ray hạng nặng cách nhiệt"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HP_SOLID_INSULATION_ENABLE.TOOLTIP"
msgid ""
"Enable an insulated variant of the heavy-duty conveyor rail.\n"
"Toggling this option also toggles all patches related to changing the insulation state of rail items, so it is not recommended to disable it for games with existing insulated rails."
msgstr ""
"Kích hoạt biến thể cách nhiệt của đường ray băng chuyền hạng nặng.\n"
"\n"
"Việc bật/tắt tùy chọn này cũng sẽ bật/tắt tất cả các bản vá liên quan đến việc thay đổi trạng thái cách nhiệt của các vật phẩm đường ray, vì vậy không khuyến khích tắt nó trong các trò chơi đã có sẵn đường ray cách nhiệt."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.NAME"
msgid "Overheat Immune High-Pressure-Pumps"
msgstr "Máy bơm áp suất cao miễn nhiễm quá nhiệt"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.HPA_TEMPIMMUNE_PUMPS.TOOLTIP"
msgid ""
"Makes high pressure pumps immune to overheating.\n"
"(Restores old behavior for existing save compatibility)"
msgstr ""
"Khiến máy bơm áp suất cao miễn nhiễm với quá nhiệt.\n"
"(Khôi phục hành vi cũ để tương thích với các tệp lưu game hiện có)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.NAME"
msgid "Logistic Rail Capacity Multiplier"
msgstr "Hệ số nhân dung tích đường ray hậu cần"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_RAIL_CAPACITY.TOOLTIP"
msgid ""
"Logistic Rails serve as an early game version to conveyor rails, lacking the mechatronic requirements and unlocking earlier at the cost of lower maximum throughput.\n"
"Total Capacity is calculated based on the base rail capacity (includes compatibility with CustomizeBuildings)"
msgstr ""
"Đường ray hậu cần đóng vai trò là phiên bản đầu game của đường ray băng chuyền, không yêu cầu cơ điện tử và mở khóa sớm hơn, đổi lại lưu lượng tối đa thấp hơn.\n"
"\n"
"Tổng dung tích được tính dựa trên dung tích đường ray cơ bản (bao gồm khả năng tương thích với CustomizeBuildings)."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.NAME"
msgid "Logistic Auto-Sweeper Range"
msgstr "Phạm vi của Máy quét tự động hậu cần"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTIC_SWEEPER_RANGE.TOOLTIP"
msgid "The Logistic Auto-Sweeper serves as an early game version of the autosweeper, trading reduced carrying capacity for a lack of a mechatronics requirement."
msgstr "Máy quét tự động hậu cần đóng vai trò là phiên bản đầu game của máy quét tự động, đổi khả năng vận chuyển giảm bớt lấy việc không yêu cầu cơ điện tử."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_LOADER
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_LOADER"
msgid "No Self Heating: Logistic Loader"
msgstr "Không tự sinh nhiệt: Bộ nạp hậu cần"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_SWEEPER
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.LOGISTIC_SWEEPER"
msgid "No Self Heating: Logistic Sweeper"
msgstr "Không tự sinh nhiệt: Máy quét hậu cần"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.LOGISTICS_NOSELFHEATING.TOOLTIP"
msgid "Makes this building no longer produce any heat."
msgstr "Khiến công trình này không còn tạo ra bất kỳ nhiệt lượng nào."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.MODELEMENTSWORLDGEN.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.MODELEMENTSWORLDGEN.NAME"
msgid "Modified Biome Composition"
msgstr "Thành phần quần xã (biome) sửa đổi"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.MODELEMENTSWORLDGEN.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.MODELEMENTSWORLDGEN.TOOLTIP"
msgid "New mod elements are embedded into the biomes during worldgen."
msgstr "Các nguyên tố mới từ mod được nhúng vào các quần xã trong quá trình khởi tạo thế giới."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OLDREFINERIES.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OLDREFINERIES.NAME"
msgid "Reenable old multi-stage refineries"
msgstr "Kích hoạt lại các lò tinh luyện đa giai đoạn cũ"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OLDREFINERIES.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OLDREFINERIES.TOOLTIP"
msgid "Reenables the two old Multi-Stage refineries in chemical processing"
msgstr "Kích hoạt lại hai Lò tinh luyện đa giai đoạn cũ trong phần xử lý hóa học."

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OVERRIDE_PRIMARYELEMENT_MAXSTACK.NAME
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OVERRIDE_PRIMARYELEMENT_MAXSTACK.NAME"
msgid "Maximum liquid/gas element stack size"
msgstr "Kích thước ngăn xếp nguyên tố chất lỏng/khí tối đa"

#. RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OVERRIDE_PRIMARYELEMENT_MAXSTACK.TOOLTIP
msgctxt "RonivansLegacy_ChemicalProcessing.STRINGS.RONIVAN_AIO_MODCONFIG.OVERRIDE_PRIMARYELEMENT_MAXSTACK.TOOLTIP"
msgid ""
"Overrides the game's internal maximum stack size value of element chunks\n"
"This is required if you want to set reservoir capacity above 100T, as the game will otherwise cut off any mass above that limit.\n"
"If any other mod sets a higher value, that higher value will be used instead.\n"
"\n"
"Requires confirming the config with \"Ok\" to affect the building editor capacity limit in the same game session."
msgstr ""

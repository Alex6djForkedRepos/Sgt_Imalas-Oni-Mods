#. ClusterTraitGenerationManager.STRINGS.ERRORMESSAGES.MISSINGWORLD
msgctxt "ClusterTraitGenerationManager.STRINGS.ERRORMESSAGES.MISSINGWORLD"
msgid "Missing Worlds!\nThe preset cannot be loaded since its start world is missing."
msgstr "Thiếu Tiểu Hành Tinh!\nKhông thể tải bản thiết lập này vì tiểu hành tinh khởi đầu của nó bị thiếu."


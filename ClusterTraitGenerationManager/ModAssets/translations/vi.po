#. ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.BLACKLISTAFFECTNONGENERICS.LABEL
msgctxt "ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.BLACKLISTAFFECTNONGENERICS.LABEL"
msgid "Blacklist affects all geysers"
msgstr "Danh sách đen áp dụng cho tất cả mạch"

#. ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.BLACKLISTAFFECTNONGENERICS.TOOLTIP
msgctxt "ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.BLACKLISTAFFECTNONGENERICS.TOOLTIP"
msgid "If enabled, the blacklist will also replace predetermined and curated geysers from the blacklist with random geysers."
msgstr "Nếu bật, danh sách đen cũng sẽ thay thế các mạch định sẵn và được chọn lọc bằng mạch ngẫu nhiên."

#. ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.BLACKLISTBUTTON.TEXT
msgctxt "ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.BLACKLISTBUTTON.TEXT"
msgid "Add geyser to blacklist"
msgstr "Thêm mạch vào danh sách đen"

#. ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.DESCRIPTOR.INFOTOOLTIP
msgctxt "ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.DESCRIPTOR.INFOTOOLTIP"
msgid "Prevent geyser types from generating as fully random geysers.\nThese are then replaced with random (generic) geysers.\nHas no effect on semi-random, curated geysers unless toggled on.\nAsteroids will share a central blacklist unless toggled off."
msgstr "Ngăn các loại mạch này xuất hiện dưới dạng mạch hoàn toàn ngẫu nhiên.\nChúng sẽ được thay thế bằng mạch ngẫu nhiên (thông thường).\nKhông ảnh hưởng đến các mạch bán ngẫu nhiên, đã được chọn lọc trừ khi được bật.\nCác tiểu hành tinh sẽ dùng chung một danh sách đen trung tâm trừ khi được tắt."

#. ClusterTraitGenerationManager.STRINGS.UI.CGM_MAINSCREENEXPORT.DETAILS.CONTENT.SCROLLRECTCONTAINER.ASTEROIDGEYSERS.CONTENT.BLACKLIST.DESCRIPTOR.LABEL

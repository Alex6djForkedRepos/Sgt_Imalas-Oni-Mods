msgid "<link=\"RTBSPACESTATIONDOCKINGDOORINDESTRUCTIBLE\">[WIP] Core Orbital Docking Port</link>"
msgstr "<link=\"RTBSPACESTATIONDOCKINGDOORINDESTRUCTIBLE\">[ĐANG PHÁT TRIỂN] Cổng Kết Nối Quỹ Đạo Lõi</link>"


#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.DESC"
msgid "Always forget to bring your stuff - now you don't!"
msgstr "Luôn quên mang đồ - giờ thì không nữa!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.EFFECT"
msgid "Allows to set custom rocket launch conditions via automation signal"
msgstr "Cho phép đặt điều kiện phóng tên lửa tùy chỉnh qua tín hiệu tự động hóa"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.LOGIC_PORT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.LOGIC_PORT"
msgid "Fulfill custom launch condition"
msgstr "Hoàn thành điều kiện phóng tùy chỉnh"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.LOGIC_PORT_ACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.LOGIC_PORT_ACTIVE"
msgid "<b><style=\"logic_on\">Green Signal</style></b>: Custom rocket launch condition will be marked as completed"
msgstr "<b><style=\"logic_on\">Tín Hiệu Xanh</style></b>: Điều kiện phóng tên lửa tùy chỉnh sẽ được đánh dấu là đã hoàn thành"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.LOGIC_PORT_INACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.LOGIC_PORT_INACTIVE"
msgid "<b><style=\"logic_off\">Red Signal</style></b>: Custom rocket launch condition will be marked as missing, preventing automatic rocket launches."
msgstr "<b><style=\"logic_off\">Tín Hiệu Đỏ</style></b>: Điều kiện phóng tên lửa tùy chỉnh sẽ được đánh dấu là còn thiếu, ngăn việc phóng tự động."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.NAME"
msgid "<link=\"RTBROCKETLOGICLAUNCHCONDITIONSETTER\">Launch Condition Sender</link>"
msgstr "<link=\"RTBROCKETLOGICLAUNCHCONDITIONSETTER\">Bộ Gửi Điều Kiện Phóng</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.STATUSITEM_TOOLTIP_ACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.STATUSITEM_TOOLTIP_ACTIVE"
msgid "The custom condition \"{0}\" is completed"
msgstr "Điều kiện tùy chỉnh \"{0}\" đã hoàn thành"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_ROCKETLOGICLAUNCHCONDITIONSETTER.STATUSITEM_TOOLTIP_INACTIVE

msgstr "<link=\"RTBBUNKERLAUNCHPAD\">Bệ Phóng Tên Lửa Nâng Cao</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIMODULEDOCKINGPORT.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIMODULEDOCKINGPORT.DESC"
msgid "Connecting with another (rocket) has never been easier."
msgstr "Kết nối với tên lửa khác chưa bao giờ dễ đến vậy."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIMODULEDOCKINGPORT.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIMODULEDOCKINGPORT.EFFECT"
msgid "Enables docking with other rockets and space stations\n\nBoth docking participants require a docking component to dock.\n\nDuplicants cannot use this docking connection.\n\nAdd it to an AI controlled rocket to allow it to dock.\n\nMultiple Modules allow multiple docking connections"
msgstr "Cho phép kết nối với các tên lửa và trạm không gian khác\n\nCả hai bên tham gia kết nối đều cần có bộ phận kết nối.\n\nĐệ không thể sử dụng kết nối này.\n\nThêm vào tên lửa điều khiển bởi AI để nó có thể kết nối.\n\nNhiều Khoang cho phép nhiều kết nối cùng lúc"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIMODULEDOCKINGPORT.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIMODULEDOCKINGPORT.NAME"
msgid "<link=\"RTBAIMODULEDOCKINGPORT\">Docking Module</link>"
msgstr "<link=\"RTBAIMODULEDOCKINGPORT\">Khoang Kết Nối</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIOCARGOBAYCLUSTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIOCARGOBAYCLUSTER.DESC"
msgid "A bit of this, a bit of that.."
msgstr "Một chút cái này, một chút cái kia.."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIOCARGOBAYCLUSTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIOCARGOBAYCLUSTER.EFFECT"
msgid "Allows Duplicants to keep a supply of all types of materials in the rocket.\n\nDoes not collect floating space resources.\n\nMust be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."
msgstr "Cho phép Đệ giữ một lượng dự trữ mọi loại vật liệu trong tên lửa.\n\nKhông thu thập tài nguyên trôi nổi trong không gian.\n\nPhải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIOCARGOBAYCLUSTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_AIOCARGOBAYCLUSTER.NAME"
msgid "<link=\"RTBAIOCARGOBAYCLUSTER\">Multi-Functional Storage Module</link>"
msgstr "<link=\"RTBAIOCARGOBAYCLUSTER\">Khoang Lưu Trữ Đa Chức Năng</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_BUNKERLAUNCHPAD.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_BUNKERLAUNCHPAD.DESC"
msgid "Một mặt phẳng mà từ đó tên lửa có thể được phóng và chúng có thể hạ cánh.\n\nFortified to withstand comets."
msgstr "Một mặt phẳng mà từ đó tên lửa có thể được phóng và chúng có thể hạ cánh.\n\nĐược gia cố để chống chịu sao chổi."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_BUNKERLAUNCHPAD.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_BUNKERLAUNCHPAD.EFFECT"
msgid "Công trình thiết yếu để xây dựng các bộ phận khác của tên lửa.\n\nCho phép phóng hoặc hạ cánh Tên lửa trên hành tinh đặt bệ.\n\n<link=\"MODULARLAUNCHPADPORTSOLID\">Các Cổng nạp tên lửa</link> cần được xây sát bên cạnh bệ phóng sẽ tự động liên kết với bệ.\n\nBlocks comets and is immune to comet damage."
msgstr "Công trình thiết yếu để xây dựng các bộ phận khác của tên lửa.\n\nCho phép phóng hoặc hạ cánh Tên lửa trên hành tinh đặt bệ.\n\n<link=\"MODULARLAUNCHPADPORTSOLID\">Các Cổng nạp tên lửa</link> cần được xây sát bên cạnh bệ phóng sẽ tự động liên kết với bệ.\n\nChặn sao chổi và miễn nhiễm với sát thương từ sao chổi."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_BUNKERLAUNCHPAD.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_BUNKERLAUNCHPAD.NAME"
msgid "<link=\"RTBBUNKERLAUNCHPAD\">Fortified Rocket Platform</link>"
msgstr "<link=\"RTBBUNKERLAUNCHPAD\">Bệ Phóng Tên Lửa Kiên Cố</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYCLUSTERLARGE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYCLUSTERLARGE.DESC"
msgid "Holds even more than a large cargo bay!"
msgstr "Chứa được còn nhiều hơn cả khoang hàng hóa cỡ lớn!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYCLUSTERLARGE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYCLUSTERLARGE.EFFECT"
msgid "Allows Duplicants to store most of the <link=\"ELEMENTSSOLID\">Solid Materials</link> found during space missions.\n\nStored resources become available to the colony upon the rocket's return. \n\nMust be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."
msgstr "Cho phép Đệ lưu trữ hầu hết <link=\"ELEMENTSSOLID\">Vật Liệu Rắn</link> thu thập được trong các nhiệm vụ không gian.\n\nTài nguyên lưu trữ sẽ có sẵn cho căn cứ khi tên lửa trở về. \n\nPhải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYCLUSTERLARGE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYCLUSTERLARGE.NAME"
msgid "<link=\"RTBCARGOBAYCLUSTERLARGE\">Colossal Cargo Bay</link>"
msgstr "<link=\"RTBCARGOBAYCLUSTERLARGE\">Khoang Hàng Hóa Khổng Lồ</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYFILTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYFILTER.DESC"
msgid "Turns out not collecting it in the first place beats having to dump the unwanted resources later."
msgstr "Hóa ra không thu thập ngay từ đầu còn tốt hơn là phải đổ bỏ tài nguyên không mong muốn sau này."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYFILTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYFILTER.EFFECT"
msgid "<b><style=\"KKeyword\">Rocket Module Upgrade</style></b>, must be constructed attached to compatible rocket modules\n\nCompatible with regular cargo bay modules.\nEnables filtering of items collected by <style=\"KKeyword\">Cargo Bays</style> via their storage filters."
msgstr "<b><style=\"KKeyword\">Nâng Cấp Khoang Tên Lửa</style></b>, phải được xây gắn liền với các khoang tên lửa tương thích\n\nTương thích với các khoang hàng hóa thông thường.\nCho phép lọc vật phẩm được thu thập bởi <style=\"KKeyword\">Khoang Hàng Hóa</style> thông qua bộ lọc lưu trữ."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYFILTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CARGOBAYFILTER.NAME"
msgid "<link=\"RTBCARGOBAYFILTER\">Cargo Bay Filter Upgrade</link>"
msgstr "<link=\"RTBCARGOBAYFILTER\">Nâng Cấp Bộ Lọc Khoang Hàng Hóa</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CO2FUELTANK.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CO2FUELTANK.DESC"
msgid "Storing additional fuel increases the distance a rocket can travel before returning."
msgstr "Lưu trữ thêm nhiên liệu giúp tăng khoảng cách tên lửa có thể di chuyển trước khi quay về."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CO2FUELTANK.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CO2FUELTANK.EFFECT"
msgid "Stores pressurized <link=\"CARBONDIOXIDE\">Carbon Dioxide</link> for <link=\"CO2ENGINE\">Carbon Dioxide Engines</link>"
msgstr "Lưu trữ <link=\"CARBONDIOXIDE\">Khí CO2</link> nén cho <link=\"CO2ENGINE\">Động Cơ Khí CO2</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CO2FUELTANK.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CO2FUELTANK.NAME"
msgid "<link=\"RTBCO2FUELTANK\">Carbon Dioxide Fuel Tank</link>"
msgstr "<link=\"RTBCO2FUELTANK\">Bình Nhiên Liệu Khí CO2</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CONNECTORBYPASSADAPTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CONNECTORBYPASSADAPTER.DESC"
msgid "Ascending to new levels"
msgstr "Vươn lên tầm cao mới"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CONNECTORBYPASSADAPTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CONNECTORBYPASSADAPTER.EFFECT"
msgid "Allows horizontal rocket ports to bypass transit tubes and tiles.\n\nAutomatically links when built to the side of a <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> or another <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link>"
msgstr "Cho phép các cổng tên lửa ngang bỏ qua ống vận chuyển và ô gạch.\n\nTự động liên kết khi được xây cạnh <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> hoặc <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link> khác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CONNECTORBYPASSADAPTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CONNECTORBYPASSADAPTER.NAME"
msgid "<link=\"RTBCONNECTORBYPASSADAPTER\">Rocket Port Bypass Adapter</link>"
msgstr "<link=\"RTBCONNECTORBYPASSADAPTER\">Bộ Chuyển Vòng Cổng Tên Lửa</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERCONTAINMENTMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERCONTAINMENTMODULE.DESC"
msgid "These critters will go where no critter has gone before."
msgstr "Những sinh vật này sẽ đến nơi chưa sinh vật nào từng đến."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERCONTAINMENTMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERCONTAINMENTMODULE.EFFECT"
msgid "This module allows the safe transport of critters to their new home. "
msgstr "Khoang này cho phép vận chuyển an toàn sinh vật đến nhà mới của chúng. "

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERCONTAINMENTMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERCONTAINMENTMODULE.NAME"
msgid "<link=\"RTBCRITTERCONTAINMENTMODULE\">[DEPRECATED] Critter Containment Module</link>"
msgstr "<link=\"RTBCRITTERCONTAINMENTMODULE\">[NGỪNG SỬ DỤNG] Khoang Chứa Sinh Vật</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERSTASISMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERSTASISMODULE.DESC"
msgid "These critters will go where no critter has gone before."
msgstr "Những sinh vật này sẽ đến nơi chưa sinh vật nào từng đến."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERSTASISMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERSTASISMODULE.EFFECT"
msgid "This module allows the safe transport of critters to their new home.\n\nStored Critters wont age."
msgstr "Khoang này cho phép vận chuyển an toàn sinh vật đến nhà mới của chúng.\n\nSinh Vật lưu trữ sẽ không già đi."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERSTASISMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_CRITTERSTASISMODULE.NAME"
msgid "<link=\"RTBCRITTERSTASISMODULE\">Critter Stasis Module</link>"
msgstr "<link=\"RTBCRITTERSTASISMODULE\">Khoang Đình Trệ Sinh Vật</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHCENTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHCENTER.DESC"
msgid "Quantum computers unlock new breakthroughs from the analysis of deep space anomalies.\n\nRequires active cooling to function optimally"
msgstr "Máy tính lượng tử mở khóa những đột phá mới từ việc phân tích các dị thường không gian sâu.\n\nCần làm mát chủ động để hoạt động tối ưu"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHCENTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHCENTER.EFFECT"
msgid "Conducts <link=\"DEEPSPACERESEARCH\">Deep Space Research</link> to unlock new technologies.\n\nConsumes <link=\"RTBDEEPSPACEINSIGHT\">Deep Space Insights</link>.\n\nAssigned Duplicants must possess the <link=\"SPACERESEARCH\">Phân tích viên</link> skill."
msgstr "Tiến hành <link=\"DEEPSPACERESEARCH\">Nghiên Cứu Không Gian Sâu</link> để mở khóa công nghệ mới.\n\nTiêu thụ <link=\"RTBDEEPSPACEINSIGHT\">Tri Thức Không Gian Sâu</link>.\n\nĐệ được chỉ định phải có kỹ năng <link=\"SPACERESEARCH\">Phân tích viên</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHCENTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHCENTER.NAME"
msgid "<link=\"RTBDEEPSPACERESEARCHCENTER\">[WIP] Quantum Computer</link>"
msgstr "<link=\"RTBDEEPSPACERESEARCHCENTER\">[ĐANG PHÁT TRIỂN] Máy Tính Lượng Tử</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHTELESCOPE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHTELESCOPE.DESC"
msgid "Deep space analysis stations scan and collect data on deep space anomalies"
msgstr "Trạm phân tích không gian sâu quét và thu thập dữ liệu về các dị thường không gian sâu"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHTELESCOPE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHTELESCOPE.EFFECT"
msgid "Allows <link=\"DEEPSPACERESEARCH\">Deep Space Research</link> to be accumulated.\n\nRequires a <link=\"RTBDEEPSPACEINSIGHT\">Deep Space Insight</link> to function."
msgstr "Cho phép tích lũy <link=\"DEEPSPACERESEARCH\">Nghiên Cứu Không Gian Sâu</link>.\n\nCần <link=\"RTBDEEPSPACEINSIGHT\">Tri Thức Không Gian Sâu</link> để hoạt động."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHTELESCOPE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DEEPSPACERESEARCHTELESCOPE.NAME"
msgid "<link=\"RTBDEEPSPACERESEARCHTELESCOPE\">[WIP] Deep Space Analysis Station</link>"
msgstr "<link=\"RTBDEEPSPACERESEARCHTELESCOPE\">[ĐANG PHÁT TRIỂN] Trạm Phân Tích Không Gian Sâu</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTANTENNA.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTANTENNA.DESC"
msgid "The transmission speed on this thing must have been great."
msgstr "Tốc độ truyền tín hiệu của thứ này hẳn phải rất tuyệt vời."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTANTENNA.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTANTENNA.EFFECT"
msgid "A broken down antenna that was once used to transmit data"
msgstr "Một ăng-ten hỏng từng được dùng để truyền dữ liệu"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTANTENNA.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTANTENNA.NAME"
msgid "<link=\"RTBDERELICTANTENNA\">Derelict Antenna</link>"
msgstr "<link=\"RTBDERELICTANTENNA\">Ăng-ten Bỏ Hoang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTDOCKINGDOOR.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTDOCKINGDOOR.DESC"
msgid "Back in the day, this was used for astronaut transfers.."
msgstr "Ngày xưa, thứ này từng dùng để chuyển phi hành gia.."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTDOCKINGDOOR.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTDOCKINGDOOR.EFFECT"
msgid "Enables Rockets with a docking bridge to connect to the derelict station.\nRockets requirWe a docking component to dock.\n\nAssigning a duplicant forces it to use the docking bridge."
msgstr "Cho phép Tên Lửa có cầu kết nối kết nối với trạm bỏ hoang.\nTên Lửa cần bộ phận kết nối để kết nối.\n\nChỉ định Đệ sẽ buộc nó sử dụng cầu kết nối."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTDOCKINGDOOR.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTDOCKINGDOOR.NAME"
msgid "<link=\"RTBDERELICTDOCKINGDOOR\">Derelict Docking Port</link>"
msgstr "<link=\"RTBDERELICTDOCKINGDOOR\">Cổng Kết Nối Bỏ Hoang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTEXTERIORWALL.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTEXTERIORWALL.DESC"
msgid "Wall panelling that creaks with age"
msgstr "Tấm vách kêu cọt kẹt vì tuổi tác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTEXTERIORWALL.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTEXTERIORWALL.EFFECT"
msgid "Prevents <link=\"ELEMENTSGAS\">Gas</link> and <link=\"ELEMENTSLIQUID\">Liquid</link> loss in space."
msgstr "Ngăn thất thoát <link=\"ELEMENTSGAS\">Khí</link> và <link=\"ELEMENTSLIQUID\">Chất Lỏng</link> ra ngoài không gian."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTEXTERIORWALL.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTEXTERIORWALL.NAME"
msgid "<link=\"RTBDERELICTEXTERIORWALL\">Derelict Wall</link>"
msgstr "<link=\"RTBDERELICTEXTERIORWALL\">Vách Bỏ Hoang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTWALLTILE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTWALLTILE.DESC"
msgid "Keeps the space out."
msgstr "Ngăn không gian bên ngoài xâm nhập."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTWALLTILE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTWALLTILE.EFFECT"
msgid "The walls of a space derelict."
msgstr "Những bức tường của một nơi bỏ hoang trong không gian."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTWALLTILE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DERELICTWALLTILE.NAME"
msgid "<link=\"RTBDERELICTWALLTILE\">Derelict Wall Tile</link>"
msgstr "<link=\"RTBDERELICTWALLTILE\">Ô Gạch Vách Bỏ Hoang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DOCKINGTUBEDOOR.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DOCKINGTUBEDOOR.DESC"
msgid "Connecting with another (rocket) has never been easier."
msgstr "Kết nối với tên lửa khác chưa bao giờ dễ đến vậy."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DOCKINGTUBEDOOR.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DOCKINGTUBEDOOR.EFFECT"
msgid "Enables docking with other rockets and space stations\n\nBoth docking participants require a docking component to dock.\n\nAssigning a duplicant forces it to use the docking bridge."
msgstr "Cho phép kết nối với các tên lửa và trạm không gian khác\n\nCả hai bên tham gia kết nối đều cần có bộ phận kết nối.\n\nChỉ định Đệ sẽ buộc nó sử dụng cầu kết nối."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DOCKINGTUBEDOOR.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DOCKINGTUBEDOOR.NAME"
msgid "<link=\"RTBDOCKINGTUBEDOOR\">Docking Bridge</link>"
msgstr "<link=\"RTBDOCKINGTUBEDOOR\">Cầu Kết Nối</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DRILLCONEDIAMONDSTORAGE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DRILLCONEDIAMONDSTORAGE.DESC"
msgid "Bringing home those minerals - for Rock and Stone!"
msgstr "Mang khoáng sản về nhà - vì Rock and Stone!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DRILLCONEDIAMONDSTORAGE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DRILLCONEDIAMONDSTORAGE.EFFECT"
msgid "Acts as a support module for a normal Drillcone.\n\nProvides additional 1500kg of diamond capacity for the drillcone.\n\nGives a 20% mining speed boost to the drillcone.\n\nCan be toggled between manual loading and automated loading via cargo loader."
msgstr "Đóng vai trò khoang hỗ trợ cho Mũi Khoan thường.\n\nCung cấp thêm 1500kg dung lượng kim cương cho mũi khoan.\n\nTăng 20% tốc độ khai thác cho mũi khoan.\n\nCó thể chuyển đổi giữa nạp thủ công và nạp tự động qua bộ nạp hàng hóa."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DRILLCONEDIAMONDSTORAGE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_DRILLCONEDIAMONDSTORAGE.NAME"
msgid "<link=\"RTBDRILLCONEDIAMONDSTORAGE\">Drillcone Service Module</link>"
msgstr "<link=\"RTBDRILLCONEDIAMONDSTORAGE\">Khoang Bảo Dưỡng Mũi Khoan</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGECARGOBAY.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGECARGOBAY.DESC"
msgid "Space food for days"
msgstr "Thực phẩm không gian dài ngày"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGECARGOBAY.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGECARGOBAY.EFFECT"
msgid "Keeps food preserved, prevent spoilage.\nCan only be filled with a cargo loader.\nContents can be accessed during the flight via wall loader"
msgstr "Giữ thực phẩm không hỏng, ngăn ôi thiu.\nChỉ có thể nạp đầy qua bộ nạp hàng hóa.\nCó thể lấy nội dung trong lúc bay qua bộ nạp trên tường"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGECARGOBAY.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGECARGOBAY.NAME"
msgid "<link=\"RTBFRIDGECARGOBAY\">Freezer Module</link>"
msgstr "<link=\"RTBFRIDGECARGOBAY\">Khoang Đông Lạnh</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.DESC"
msgid "Food spoilage can be slowed by ambient conditions as well as by refrigerators."
msgstr "Thực phẩm ôi thiu có thể được làm chậm lại nhờ điều kiện môi trường xung quanh cũng như tủ lạnh."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.EFFECT"
msgid "Has to be attached to the rocket wall.\n\nStores a small amount of <link=\"FOOD\">Food</link> at an ideal <link=\"HEAT\">Temperature</link> to prevent spoilage.\n\nWill pull food from a connected <link=\"RTBFRIDGECARGOBAY\">Freezer Module</link> when low on food."
msgstr "Phải được gắn vào tường tên lửa.\n\nLưu trữ một lượng nhỏ <link=\"FOOD\">Thực Phẩm</link> ở <link=\"HEAT\">Nhiệt Độ</link> lý tưởng để ngăn ôi thiu.\n\nSẽ lấy thực phẩm từ <link=\"RTBFRIDGECARGOBAY\">Khoang Đông Lạnh</link> đã kết nối khi thiếu thực phẩm."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT"
msgid "Full/Not Full"
msgstr "Đầy/Chưa Đầy"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_ACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_ACTIVE"
msgid "Sends a <b><style=\"logic_on\">Green Signal</style></b> when full"
msgstr "Gửi <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> khi đầy"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_ACTIVE_PULL
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_ACTIVE_PULL"
msgid "<b><style=\"logic_on\">Green Signal</style></b>: Building will pull more food from the Freezer Module when below 1kg of food."
msgstr "<b><style=\"logic_on\">Tín Hiệu Xanh</style></b>: Công trình sẽ lấy thêm thực phẩm từ Khoang Đông Lạnh khi dưới 1kg thực phẩm."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_INACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_INACTIVE"
msgid "Otherwise, sends a <b><style=\"logic_off\">Red Signal</style></b>"
msgstr "Ngược lại, gửi <b><style=\"logic_off\">Tín Hiệu Đỏ</style></b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_INACTIVE_PULL
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_INACTIVE_PULL"
msgid "<b><style=\"logic_off\">Red Signal</style></b>: Building wont pull any more food even when below 1kg."
msgstr "<b><style=\"logic_off\">Tín Hiệu Đỏ</style></b>: Công trình sẽ không lấy thêm thực phẩm ngay cả khi dưới 1kg."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_PULL
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.LOGIC_PORT_PULL"
msgid "Pull food from Freezer Module"
msgstr "Lấy thực phẩm từ Khoang Đông Lạnh"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_FRIDGEMODULEACCESSHATCH.NAME"
msgid "<link=\"RTBFRIDGEMODULEACCESSHATCH\">Freezer Access Hatch</link>"
msgstr "<link=\"RTBFRIDGEMODULEACCESSHATCH\">Cửa Tiếp Cận Khoang Đông Lạnh</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GASCARGOBAYCLUSTERLARGE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GASCARGOBAYCLUSTERLARGE.DESC"
msgid "Holds even more than a large gas cargo canister!"
msgstr "Chứa được còn nhiều hơn cả bình khí hàng hóa cỡ lớn!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GASCARGOBAYCLUSTERLARGE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GASCARGOBAYCLUSTERLARGE.EFFECT"
msgid "Allows Duplicants to store most of the <link=\"ELEMENTSGAS\">Gas</link> resources found during space missions.\n\nStored resources become available to the colony upon the rocket's return.\n\nMust be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."
msgstr "Cho phép Đệ lưu trữ hầu hết tài nguyên <link=\"ELEMENTSGAS\">Khí</link> thu thập được trong các nhiệm vụ không gian.\n\nTài nguyên lưu trữ sẽ có sẵn cho căn cứ khi tên lửa trở về.\n\nPhải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GASCARGOBAYCLUSTERLARGE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GASCARGOBAYCLUSTERLARGE.NAME"
msgid "<link=\"RTBGASCARGOBAYCLUSTERLARGE\">Colossal Gas Cargo Canister</link>"
msgstr "<link=\"RTBGASCARGOBAYCLUSTERLARGE\">Bình Chứa Khí Khổng Lồ</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.DESC"
msgid "Converts <link=\"CARBON\">Coal</link> into electrical <link=\"POWER\">Power</link>."
msgstr "Chuyển hóa <link=\"CARBON\">Than</link> thành <link=\"POWER\">Điện</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.EFFECT"
msgid "Burning coal produces more energy than manual power, who could have thought this also works in space.\n\n If there is atleast one battery connected, the generator will stop producing if the battery is above 95% charge."
msgstr "Đốt than tạo ra nhiều năng lượng hơn quay tay, ai mà nghĩ được điều này cũng hoạt động trong không gian.\n\n Nếu có ít nhất một pin được kết nối, máy phát sẽ ngừng sản xuất khi pin đã sạc trên 95%."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.NAME"
msgid "<link=\"RTBGENERATORCOALMODULE\">Coal Generator Module</link>"
msgstr "<link=\"RTBGENERATORCOALMODULE\">Khoang Máy Phát Điện Than</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.SIDESCREEN_TOOLTIP
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_GENERATORCOALMODULE.SIDESCREEN_TOOLTIP"
msgid "Duplicants will be requested to deliver <style=\"KKeyword\">{0}</style> when the amount stored falls below <b>{1}</b>"
msgstr "Đệ sẽ được yêu cầu vận chuyển <style=\"KKeyword\">{0}</style> khi lượng lưu trữ giảm xuống dưới <b>{1}</b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEMEDIUMEXPANDED.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEMEDIUMEXPANDED.DESC"
msgid "Giúp đệ du hành vũ trụ an toàn hơn... Chắc vậy."
msgstr "Giúp đệ du hành vũ trụ an toàn hơn... Chắc vậy."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEMEDIUMEXPANDED.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEMEDIUMEXPANDED.EFFECT"
msgid "Có chức năng giống như phòng lái.\n\nCó thể chở 10 thằng đệ.\n\nMột tên lửa chỉ được xây một khoang lái.\n\nPhải được xây trên <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."
msgstr "Có chức năng giống như phòng lái.\n\nCó thể chở 10 đứa đệ.\n\nMột tên lửa chỉ được xây một khoang lái.\n\nPhải được xây trên <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEMEDIUMEXPANDED.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEMEDIUMEXPANDED.NAME"
msgid "<link=\"RTBHABITATMODULEMEDIUMEXPANDED\">Extended Spacefarer Module</link>"
msgstr "<link=\"RTBHABITATMODULEMEDIUMEXPANDED\">Khoang Phi Hành Gia Mở Rộng</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEPLATEDLARGE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEPLATEDLARGE.DESC"
msgid "Chở được một đệ, có tầm nhìn ngắm được toàn bộ các khoang phía dưới."
msgstr "Chở được một đứa đệ, có tầm nhìn ngắm được toàn bộ các khoang phía dưới."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEPLATEDLARGE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEPLATEDLARGE.EFFECT"
msgid "Là mũi tên lửa và cũng là khoang lái.\n\nChỉ chở được một thằng đệ.\n\nMột tên lửa chỉ được xây một khoang lái.\n\nPhải xây <link=\"LAUNCHPAD\">bệ phóng tên lửa</link> trước.\n\nPhải xây ở đỉnh tên lửa.\n\nInterior is fully shielded from radiation."
msgstr "Là mũi tên lửa và cũng là khoang lái.\n\nChỉ chở được một đứa đệ.\n\nMột tên lửa chỉ được xây một khoang lái.\n\nPhải xây <link=\"LAUNCHPAD\">bệ phóng tên lửa</link> trước.\n\nPhải xây ở đỉnh tên lửa.\n\nBên trong được che chắn hoàn toàn khỏi phóng xạ."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEPLATEDLARGE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULEPLATEDLARGE.NAME"
msgid "<link=\"RTBHABITATMODULEPLATEDLARGE\">Plated Spacefarer Nosecone</link>"
msgstr "<link=\"RTBHABITATMODULEPLATEDLARGE\">Mũi Tên Lửa Phi Hành Gia Bọc Giáp</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESMALLEXPANDED.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESMALLEXPANDED.DESC"
msgid "Chở được một đệ, có tầm nhìn ngắm được toàn bộ các khoang phía dưới."
msgstr "Chở được một đứa đệ, có tầm nhìn ngắm được toàn bộ các khoang phía dưới."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESMALLEXPANDED.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESMALLEXPANDED.EFFECT"
msgid "Là mũi tên lửa và cũng là khoang lái.\n\nChỉ chở được một thằng đệ.\n\nMột tên lửa chỉ được xây một khoang lái.\n\nPhải xây <link=\"LAUNCHPAD\">bệ phóng tên lửa</link> trước.\n\nPhải xây ở đỉnh tên lửa."
msgstr "Là mũi tên lửa và cũng là khoang lái.\n\nChỉ chở được một đứa đệ.\n\nMột tên lửa chỉ được xây một khoang lái.\n\nPhải xây <link=\"LAUNCHPAD\">bệ phóng tên lửa</link> trước.\n\nPhải xây ở đỉnh tên lửa."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESMALLEXPANDED.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESMALLEXPANDED.NAME"
msgid "<link=\"RTBHABITATMODULESMALLEXPANDED\">Extended Solo Spacefarer Nosecone</link>"
msgstr "<link=\"RTBHABITATMODULESMALLEXPANDED\">Mũi Tên Lửa Phi Hành Gia Đơn Mở Rộng</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESTARGAZER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESTARGAZER.DESC"
msgid "The stars have never felt this close before like in this Command Module."
msgstr "Những vì sao chưa bao giờ gần đến vậy như trong Khoang Điều Khiển này."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESTARGAZER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESTARGAZER.EFFECT"
msgid "Closes during starts and landings to protect the glass\n\nFunctions as a Command Module and a Nosecone.\n\nOne Command Module may be installed per rocket.\n\nMust be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>. \n\nMust be built at the top of a rocket.\n\nGreat for looking at the stars or a nice sunbathing during the flight."
msgstr "Đóng lại khi cất/hạ cánh để bảo vệ kính\n\nHoạt động như Khoang Điều Khiển và Mũi Tên Lửa.\n\nMỗi tên lửa chỉ được lắp một Khoang Điều Khiển.\n\nPhải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>. \n\nPhải xây ở đỉnh tên lửa.\n\nTuyệt vời để ngắm sao hoặc tắm nắng trong chuyến bay."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESTARGAZER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HABITATMODULESTARGAZER.NAME"
msgid "<link=\"RTBHABITATMODULESTARGAZER\">Stargazer Nosecone</link>"
msgstr "<link=\"RTBHABITATMODULESTARGAZER\">Mũi Tên Lửa Ngắm Sao</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPBATTERYMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPBATTERYMODULE.DESC"
msgid "Particles packed up and ready to visit the stars."
msgstr "Các hạt được đóng gói sẵn sàng viếng thăm những vì sao."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPBATTERYMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPBATTERYMODULE.EFFECT"
msgid "Stores Radbolts in a high-energy state, ready for transport.\n\nRequires a <b><style=\"logic_on\">Green Signal</style></b> to release radbolts from storage when the Radbolt threshold is reached.\n\nRadbolts in storage won't decay as long as the module is powered, this can either happen via its built in solar panels or power connectors on battery- and spacefarer modules\n\nAutomatically refills a <link=\"RYBNOSECONEHEPHARVEST\">Laser Drillcone</link>"
msgstr "Lưu trữ Radbolt ở trạng thái năng lượng cao, sẵn sàng vận chuyển.\n\nCần <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> để giải phóng radbolt khỏi kho lưu trữ khi đạt ngưỡng Radbolt.\n\nRadbolt trong kho sẽ không phân rã chừng nào khoang còn được cấp điện, có thể qua tấm pin mặt trời tích hợp hoặc cổng điện trên các khoang pin và khoang phi hành gia\n\nTự động nạp lại cho <link=\"RYBNOSECONEHEPHARVEST\">Mũi Khoan Laser</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPBATTERYMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPBATTERYMODULE.NAME"
msgid "<link=\"RTBHEPBATTERYMODULE\">Radbolt Chamber Module</link>"
msgstr "<link=\"RTBHEPBATTERYMODULE\">Khoang Buồng Radbolt</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPFUELLOADER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPFUELLOADER.DESC"
msgid "\"Shoving everything in there\" - now with higly energized particles."
msgstr "\"Nhét hết vào trong đó\" - giờ có thêm hạt năng lượng cao."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPFUELLOADER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPFUELLOADER.EFFECT"
msgid "Fills all sorts of Radbolt Storages.\nAllows fueling a Radbolt Engine and the Laser Drillcone\n\nAutomatically links when built to the side of a <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> or another <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link>"
msgstr "Nạp mọi loại Kho Radbolt.\nCho phép nạp nhiên liệu Động Cơ Radbolt và Mũi Khoan Laser\n\nTự động liên kết khi được xây cạnh <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> hoặc <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link> khác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPFUELLOADER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_HEPFUELLOADER.NAME"
msgid "<link=\"RTBHEPFUELLOADER\">Radbolt Loader</link>"
msgstr "<link=\"RTBHEPFUELLOADER\">Bộ Nạp Radbolt</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_IONENGINECLUSTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_IONENGINECLUSTER.DESC"
msgid "Rockets can be used to send Duplicants into space and retrieve rare resources."
msgstr "Tên lửa có thể được dùng để đưa Đệ vào không gian và thu thập tài nguyên hiếm."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_IONENGINECLUSTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_IONENGINECLUSTER.EFFECT"
msgid "Uses large amounts of <link=\"POWER\">Power</link> to ionize <link=\"WATER\">Water</link>, ejecting the ionized particles outwards to propel rockets for long-range space exploration.\n\nPower is drawn from battery modules.\n\nEngine must be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>"
msgstr "Sử dụng lượng lớn <link=\"POWER\">Điện</link> để ion hóa <link=\"WATER\">Nước</link>, đẩy các hạt ion hóa ra ngoài để đẩy tên lửa cho các chuyến thám hiểm không gian tầm xa.\n\nĐiện được lấy từ các khoang pin.\n\nĐộng cơ phải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_IONENGINECLUSTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_IONENGINECLUSTER.NAME"
msgid "<link=\"RTBIONENGINECLUSTER\">Ion Engine</link>"
msgstr "<link=\"RTBIONENGINECLUSTER\">Động Cơ Ion</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LADDERCONNECTIONADAPTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LADDERCONNECTIONADAPTER.DESC"
msgid "Connecting rocket platforms, now with verticality"
msgstr "Kết nối các bệ phóng tên lửa, giờ có thêm chiều dọc"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LADDERCONNECTIONADAPTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LADDERCONNECTIONADAPTER.EFFECT"
msgid "Connects adjacent rocket platforms while doubling as a ladder.\n\nAutomatically links when built to the side of a <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> or another <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link>"
msgstr "Kết nối các bệ phóng tên lửa liền kề trong khi đóng vai trò như một chiếc thang.\n\nTự động liên kết khi được xây cạnh <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> hoặc <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link> khác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LADDERCONNECTIONADAPTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LADDERCONNECTIONADAPTER.NAME"
msgid "<link=\"RTBWALLCONNECTIONADAPTER\">Rocket Port Ladder Adapter</link>"
msgstr "<link=\"RTBWALLCONNECTIONADAPTER\">Bộ Chuyển Cổng Tên Lửa Tích Hợp Thang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LANDERROCKETPLATFORM.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LANDERROCKETPLATFORM.DESC"
msgid "Perfect for a first landing"
msgstr "Hoàn hảo cho lần hạ cánh đầu tiên"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LANDERROCKETPLATFORM.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LANDERROCKETPLATFORM.NAME"
msgid "<link=\"RTBLANDERROCKETPLATFORM\">Deployable Rocket Platform</link>"
msgstr "<link=\"RTBLANDERROCKETPLATFORM\">Bệ Phóng Tên Lửa Có Thể Triển Khai</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCARGOBAYCLUSTERLARGE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCARGOBAYCLUSTERLARGE.DESC"
msgid "Holds even more than a large cargo tank!"
msgstr "Chứa được còn nhiều hơn cả bình hàng hóa cỡ lớn!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCARGOBAYCLUSTERLARGE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCARGOBAYCLUSTERLARGE.EFFECT"
msgid "Allows Duplicants to store most of the <link=\"ELEMENTSLIQUID\">Liquid</link> resources found during space missions.\n\nStored resources become available to the colony upon the rocket's return.\n\nMust be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."
msgstr "Cho phép Đệ lưu trữ hầu hết tài nguyên <link=\"ELEMENTSLIQUID\">Chất Lỏng</link> thu thập được trong các nhiệm vụ không gian.\n\nTài nguyên lưu trữ sẽ có sẵn cho căn cứ khi tên lửa trở về.\n\nPhải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCARGOBAYCLUSTERLARGE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCARGOBAYCLUSTERLARGE.NAME"
msgid "<link=\"RTBLIQUIDCARGOBAYCLUSTERLARGE\">Colossal Liquid Cargo Tank</link>"
msgstr "<link=\"RTBLIQUIDCARGOBAYCLUSTERLARGE\">Bình Chứa Chất Lỏng Khổng Lồ</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCHLORINEOXIDIZERTANK.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCHLORINEOXIDIZERTANK.DESC"
msgid "Liquid chlorine improves the thrust-to-mass ratio of rocket fuels."
msgstr "Clo lỏng cải thiện tỷ lệ lực đẩy trên khối lượng của nhiên liệu tên lửa."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCHLORINEOXIDIZERTANK.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCHLORINEOXIDIZERTANK.EFFECT"
msgid "Stores <link=\"CHLORINE\">Liquid Chlorine</link> for burning rocket fuels. \n\nMust be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>.\n\nThe oxidizer efficiency of liquid chlorine sits between those of oxylite and liquid oxygen (3)."
msgstr "Lưu trữ <link=\"CHLORINE\">Clo Lỏng</link> để đốt nhiên liệu tên lửa. \n\nPhải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>.\n\nHiệu suất oxy hóa của clo lỏng nằm giữa oxylite và oxy lỏng (3)."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCHLORINEOXIDIZERTANK.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDCHLORINEOXIDIZERTANK.NAME"
msgid "<link=\"RTBLIQUIDCHLORINEOXIDIZERTANK\">Liquid Chlorine Oxidizer Tank</link>"
msgstr "<link=\"RTBLIQUIDCHLORINEOXIDIZERTANK\">Bình Oxy Hóa Clo Lỏng</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDFUELTANKCLUSTERSMALL.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDFUELTANKCLUSTERSMALL.DESC"
msgid "Lưu trữ thêm nhiên liệu để có thể tăng khoảng cách mà tên lửa có thể di chuyển đến trước khi tên lửa trở về."
msgstr "Lưu trữ thêm nhiên liệu để có thể tăng khoảng cách mà tên lửa có thể di chuyển đến trước khi tên lửa trở về."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDFUELTANKCLUSTERSMALL.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDFUELTANKCLUSTERSMALL.EFFECT"
msgid "Chứa nhiên liệu dạng <link=\"ELEMENTSLIQUID\">lỏng</link> cho động cơ.\n\nLoại nhiên liệu được lưu trữ sẽ phụ thuộc vào loại động cơ đã xây. \n\nPhải xây <link=\"LAUNCHPAD\">bệ phóng tên lửa</link> trước."
msgstr "Chứa nhiên liệu dạng <link=\"ELEMENTSLIQUID\">lỏng</link> cho động cơ.\n\nLoại nhiên liệu được lưu trữ sẽ phụ thuộc vào loại động cơ đã xây. \n\nPhải xây <link=\"LAUNCHPAD\">bệ phóng tên lửa</link> trước."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDFUELTANKCLUSTERSMALL.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_LIQUIDFUELTANKCLUSTERSMALL.NAME"
msgid "<link=\"RTBLIQUIDFUELTANKCLUSTERSMALL\">Small Liquid Fuel Tank</link>"
msgstr "<link=\"RTBLIQUIDFUELTANKCLUSTERSMALL\">Bình Nhiên Liệu Lỏng Nhỏ</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NATGASENGINECLUSTER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NATGASENGINECLUSTER.DESC"
msgid "Rockets can be used to send Duplicants into space and retrieve rare resources."
msgstr "Tên lửa có thể được dùng để đưa Đệ vào không gian và thu thập tài nguyên hiếm."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NATGASENGINECLUSTER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NATGASENGINECLUSTER.EFFECT"
msgid "Burns <link=\"METHANE\">Natural Gas</link> to propel rockets for mid-range space exploration.\n\nEngine must be built via <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>"
msgstr "Đốt <link=\"METHANE\">Khí Tự Nhiên</link> để đẩy tên lửa cho các chuyến thám hiểm không gian tầm trung.\n\nĐộng cơ phải được xây thông qua <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NATGASENGINECLUSTER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NATGASENGINECLUSTER.NAME"
msgid "<link=\"RTBNATGASENGINECLUSTER\">Natural Gas Engine</link>"
msgstr "<link=\"RTBNATGASENGINECLUSTER\">Động Cơ Khí Tự Nhiên</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NOSECONESOLAR.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NOSECONESOLAR.DESC"
msgid "Mọi tên lửa đều cần một nosecone để bay."
msgstr "Mọi tên lửa đều cần một nosecone để bay."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NOSECONESOLAR.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NOSECONESOLAR.EFFECT"
msgid "Bảo vệ tên lửa trong quá trình cất cánh và hạ cánh, cho phép du hành vũ trụ.\n\nPhải được xây dựng thông qua <link=\"LAUNCHPAD\">Bệ Phóng Tên Lửa</link>, và được lắp đặt ở phần trên cùng của tên lửa.\n\nConverts <link=\"LIGHT\">Sunlight</link> into electrical <link=\"POWER\">Power</link> for use on rockets.\n\nMust be exposed to space."
msgstr "Bảo vệ tên lửa trong quá trình cất cánh và hạ cánh, cho phép du hành vũ trụ.\n\nPhải được xây dựng thông qua <link=\"LAUNCHPAD\">Bệ Phóng Tên Lửa</link>, và được lắp đặt ở phần trên cùng của tên lửa.\n\nChuyển hóa <link=\"LIGHT\">Ánh Sáng Mặt Trời</link> thành <link=\"POWER\">Điện</link> để sử dụng trên tên lửa.\n\nPhải được tiếp xúc với không gian."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NOSECONESOLAR.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_NOSECONESOLAR.NAME"
msgid "<link=\"RTBNOSECONESOLAR\">Solar Nosecone</link>"
msgstr "<link=\"RTBNOSECONESOLAR\">Mũi Tên Lửa Năng Lượng Mặt Trời</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POI_SOLARPANEL.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POI_SOLARPANEL.DESC"
msgid "It has stopped working"
msgstr "Nó đã ngừng hoạt động"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POI_SOLARPANEL.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POI_SOLARPANEL.EFFECT"
msgid "The the dysfunctional remains of a solar panel."
msgstr "Phần còn lại hỏng hóc của một tấm pin mặt trời."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POI_SOLARPANEL.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POI_SOLARPANEL.NAME"
msgid "<link=\"RTBPOISOLARPANEL\">Derelict Solar Panel</link>"
msgstr "<link=\"RTBPOISOLARPANEL\">Tấm Pin Mặt Trời Bỏ Hoang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.DESC"
msgid "How much stuff is out there?"
msgstr "Ngoài kia còn bao nhiêu thứ nữa?"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.EFFECT"
msgid "After pointing the building at a space poi, the building will output logic signals based on the poi artifact existing and the mass remaining in the poi."
msgstr "Sau khi trỏ công trình vào một POI không gian, công trình sẽ xuất tín hiệu logic dựa trên việc POI có cổ vật và khối lượng còn lại trong POI."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_ARTIFACT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_ARTIFACT"
msgid "POI has Artifact"
msgstr "POI Có Cổ Vật"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_ARTIFACT_ACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_ARTIFACT_ACTIVE"
msgid "Sends a <b><style=\"logic_on\">Green Signal</style></b> when the targeted POI has an artifact"
msgstr "Gửi <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> khi POI được nhắm tới có cổ vật"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_ARTIFACT_INACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_ARTIFACT_INACTIVE"
msgid "Otherwise, sends a <b><style=\"logic_off\">Red Signal</style></b>"
msgstr "Ngược lại, gửi <b><style=\"logic_off\">Tín Hiệu Đỏ</style></b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_CAPACITY
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_CAPACITY"
msgid "POI mass above set threshold."
msgstr "Khối Lượng POI trên ngưỡng đã đặt."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_CAPACITY_ACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_CAPACITY_ACTIVE"
msgid "Sends a <b><style=\"logic_on\">Green Signal</style></b> when the targeted POI has more than the configured mass remaining"
msgstr "Gửi <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> khi POI được nhắm tới còn lại khối lượng nhiều hơn mức đã cấu hình"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_CAPACITY_INACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.LOGIC_PORT_CAPACITY_INACTIVE"
msgid "Otherwise, sends a <b><style=\"logic_off\">Red Signal</style></b>"
msgstr "Ngược lại, gửi <b><style=\"logic_off\">Tín Hiệu Đỏ</style></b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.ALL
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.ALL"
msgid "Mode: All Resources"
msgstr "Chế Độ: Tất Cả Tài Nguyên"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.ALL_TOOLTIP
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.ALL_TOOLTIP"
msgid "Include both freely collectable resources and those that require drilling."
msgstr "Bao gồm cả tài nguyên thu thập tự do lẫn tài nguyên cần khai thác."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.FLOATING_ONLY
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.FLOATING_ONLY"
msgid "Mode: Collectable Resources only"
msgstr "Chế Độ: Chỉ Tài Nguyên Có Thể Thu Thập"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.FLOATING_ONLY_TOOLTIP
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.FLOATING_ONLY_TOOLTIP"
msgid "Only include collectable resources that do not require a drillcone."
msgstr "Chỉ bao gồm tài nguyên có thể thu thập không cần mũi khoan."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.HARVESTABLE_ONLY
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.HARVESTABLE_ONLY"
msgid "Mode: Drillable Resources only"
msgstr "Chế Độ: Chỉ Tài Nguyên Có Thể Khai Thác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.HARVESTABLE_ONLY_TOOLTIP
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.MODESWITCH.HARVESTABLE_ONLY_TOOLTIP"
msgid "Only include resources of the POI that require drilling"
msgstr "Chỉ bao gồm tài nguyên của POI cần khai thác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.NAME"
msgid "<link=\"RTBPOICAPACITYSENSOR\">Starmap POI Capacity Sensor</link>"
msgstr "<link=\"RTBPOICAPACITYSENSOR\">Cảm Biến Dung Lượng POI Bản Đồ Sao</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.REMAININGMASS
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.REMAININGMASS"
msgid "Remaining Mass in POI"
msgstr "Khối Lượng Còn Lại trong POI"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.REMAININGMASS_TOOLTIP_ABOVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.REMAININGMASS_TOOLTIP_ABOVE"
msgid "Will send a <b><style=\"logic_on\">Green Signal</style></b> if the <style=\"KKeyword\">remaining Mass in the POI</style> is above <b>{0}</b>"
msgstr "Sẽ gửi <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> nếu <style=\"KKeyword\">khối lượng còn lại trong POI</style> trên <b>{0}</b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.REMAININGMASS_TOOLTIP_BELOW
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.REMAININGMASS_TOOLTIP_BELOW"
msgid "Will send a <b><style=\"logic_on\">Green Signal</style></b> if the <style=\"KKeyword\">remaining Mass in the POI</style> is below <b>{0}</b>"
msgstr "Sẽ gửi <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> nếu <style=\"KKeyword\">khối lượng còn lại trong POI</style> dưới <b>{0}</b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.SIDESCREENTITLE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_POICAPACITYSENSOR.SIDESCREENTITLE"
msgid "Remaining Mass"

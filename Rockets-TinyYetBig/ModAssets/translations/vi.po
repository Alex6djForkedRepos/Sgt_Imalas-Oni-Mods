#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_STEAMGENERATORMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_STEAMGENERATORMODULE.DESC"
msgid "Useful for converting hot steam into usable power."
msgstr "Hữu ích để chuyển hóa hơi nước nóng thành điện năng."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_STEAMGENERATORMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_STEAMGENERATORMODULE.EFFECT"
msgid "Draws in <link=\"STEAM\">Steam</link> from gas storage modules and uses it to generate electrical <link=\"POWER\">Power</link>.\n\n If there are liquid storage modules with appropriate filters set, outputs hot <link=\"WATER\">Water</link> to them.\n\n If there is atleast one battery connected, the generator will stop producing if the battery is above 95% charge."
msgstr "Hút <link=\"STEAM\">Hơi Nước</link> từ các khoang lưu trữ khí và dùng nó để tạo ra <link=\"POWER\">Điện</link>.\n\n Nếu có khoang lưu trữ chất lỏng với bộ lọc phù hợp, sẽ xuất <link=\"WATER\">Nước</link> nóng vào đó.\n\n Nếu có ít nhất một pin được kết nối, máy phát sẽ ngừng sản xuất khi pin đã sạc trên 95%."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_STEAMGENERATORMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_STEAMGENERATORMODULE.NAME"
msgid "<link=\"RTBSTEAMGENERATORMODULE\">Steam Generator Module</link>"
msgstr "<link=\"RTBSTEAMGENERATORMODULE\">Khoang Máy Phát Điện Hơi Nước</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_TECHUNLOCK.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_TECHUNLOCK.DESC"
msgid "An ancient computer terminal, it still runs on Windows 42\n\n\nThis computer terminal is somehow still able to function.\n\nIt contains valuable insights on the mysteries of the cosmos\n\nInteract to unlock new Technologies."
msgstr "Một máy tính cổ đại, vẫn còn chạy Windows 42\n\n\nChiếc máy tính này bằng cách nào đó vẫn còn hoạt động được.\n\nNó chứa những hiểu biết quý giá về bí ẩn vũ trụ\n\nTương tác để mở khóa Công Nghệ mới."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_TECHUNLOCK.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_TECHUNLOCK.NAME"
msgid "<link=\"RTBTECHUNLOCK\">Abandoned Station Computer</link>"
msgstr "<link=\"RTBTECHUNLOCK\">Máy Tính Trạm Bỏ Hoang</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.DESC"
msgid "Fueling Rockets has never been easier!"
msgstr "Nạp nhiên liệu tên lửa chưa bao giờ dễ đến vậy!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.EFFECT"
msgid "Refuels connected rockets with the appropriate fuel.\n\nAutomatically links when built to the side of a <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> or another <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link>"
msgstr "Nạp lại nhiên liệu phù hợp cho tên lửa đã kết nối.\n\nTự động liên kết khi được xây cạnh <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> hoặc <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link> khác"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.LOGIC_PORT_ROCKETLOADER
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.LOGIC_PORT_ROCKETLOADER"
msgid "Currently Loading/Unloading"
msgstr "Đang Nạp/Dỡ Hàng"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.LOGIC_PORT_ROCKETLOADER_ACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.LOGIC_PORT_ROCKETLOADER_ACTIVE"
msgid "Sends a <b><style=\"logic_on\">Green Signal</style></b> when building is currently loading or unloading a rocket"
msgstr "Gửi <b><style=\"logic_on\">Tín Hiệu Xanh</style></b> khi công trình đang nạp hoặc dỡ hàng tên lửa"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.LOGIC_PORT_ROCKETLOADER_INACTIVE
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.LOGIC_PORT_ROCKETLOADER_INACTIVE"
msgid "Otherwise, sends a <b><style=\"logic_off\">Red Signal</style></b>"
msgstr "Ngược lại, gửi <b><style=\"logic_off\">Tín Hiệu Đỏ</style></b>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALFUELLOADER.NAME"
msgid "<link=\"RTBUNIVERSALFUELLOADER\">Rocket Fuel Loader</link>"
msgstr "<link=\"RTBUNIVERSALFUELLOADER\">Bộ Nạp Nhiên Liệu Tên Lửa</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALOXIDIZERLOADER.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALOXIDIZERLOADER.DESC"
msgid "Fueling Rockets has never been easier!"
msgstr "Nạp nhiên liệu tên lửa chưa bao giờ dễ đến vậy!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALOXIDIZERLOADER.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_UNIVERSALOXIDIZERLOADER.EFFECT"
msgid "Refuels connected rockets with the appropriate oxidizer\n\nAutomatically links when built to the side of a <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> or another <link=\"MODULARLAUNCHPADPORTSOLID\">Cổng Tên Lửa</link>"

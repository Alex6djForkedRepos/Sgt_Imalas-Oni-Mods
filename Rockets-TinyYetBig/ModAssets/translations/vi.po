msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RYB_NOSECONEHEPHARVEST.EFFECT"
msgid "Giúp tên lửa thu lượm được các tài nguyên dạng <link=\"ELEMENTSGAS\">Khí</link>, <link=\"ELEMENTSLIQUID\">Lỏng</link> và <link=\"ELEMENTSSOLID\">Rắn</link> từ các vùng tài nguyên nằm rải rác trong vũ trụ.\n\nĐộng cơ phải được xây trên <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>.\n\nPhải được xây ở đỉnh tên lửa có khoang hàng hóa quỹ đạo để chứa các loại <link=\"ELEMENTSGAS\">Chất Khí</link>, <link=\"ELEMENTSLIQUID\">Chất Lỏng</link> hoặc <link=\"ELEMENTSSOLID\">Chất Rắn</link> tương ứng."
msgstr "Giúp tên lửa thu lượm được các tài nguyên dạng <link=\"ELEMENTSGAS\">Khí</link>, <link=\"ELEMENTSLIQUID\">Lỏng</link> và <link=\"ELEMENTSSOLID\">Rắn</link> từ các vùng tài nguyên nằm rải rác trong vũ trụ.\n\nĐộng cơ phải được xây trên <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link>.\n\nPhải được xây ở đỉnh tên lửa có khoang hàng hóa quỹ đạo để chứa các loại <link=\"ELEMENTSGAS\">Chất Khí</link>, <link=\"ELEMENTSLIQUID\">Chất Lỏng</link> hoặc <link=\"ELEMENTSSOLID\">Chất Rắn</link> tương ứng."


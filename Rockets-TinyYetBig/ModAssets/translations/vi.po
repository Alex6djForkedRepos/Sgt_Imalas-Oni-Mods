msgstr "Bệ Phóng Tên Lửa"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_RTGGENERATORMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_RTGGENERATORMODULE.DESC"
msgid "Through exploitation of the natural decay of enriched Uranium, this elegantly simple power generator can provide consistent, stable power for hundreds of cycles."
msgstr "Nhờ khai thác sự phân rã tự nhiên của Uranium làm giàu, máy phát điện đơn giản mà tinh tế này có thể cung cấp điện ổn định, liên tục trong hàng trăm chu kỳ."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_RTGGENERATORMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_RTGGENERATORMODULE.EFFECT"
msgid "After adding 50 kg of enriched Uranium, this module will constantly produce 120 W of energy until all of the uranium is depleted.\n\nIt will take 50 Cycles for the uranium to decay."
msgstr "Sau khi thêm 50 kg Uranium làm giàu, khoang này sẽ liên tục sản xuất 120 W năng lượng cho đến khi hết uranium.\n\nSẽ mất 50 Chu Kỳ để uranium phân rã."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_RTGGENERATORMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_RTGGENERATORMODULE.NAME"
msgid "<link=\"RTBRTGGENERATORMODULE\">Radioisotope Thermoelectric Generator</link>"
msgstr "<link=\"RTBRTGGENERATORMODULE\">Máy Phát Nhiệt Điện Đồng Vị Phóng Xạ</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SMOLBATTERYMODULE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SMOLBATTERYMODULE.DESC"
msgid "Sạc module pin trước khi cất cánh giúp cung cấp năng lượng cho các Công Trình dễ dàng hơn trong suốt chuyến bay."
msgstr "Sạc module pin trước khi cất cánh giúp cung cấp năng lượng cho các Công Trình dễ dàng hơn trong suốt chuyến bay."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SMOLBATTERYMODULE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SMOLBATTERYMODULE.EFFECT"
msgid "Tích trữ <link=\"POWER\">điện</link> từ động cơ tên lửa hoặc từ <link=\"LAUNCHPAD\">bệ phóng</link>.\n\nĐiện được tích trữ có thể dùng trong khoang hành khách thông qua <link=\"ROCKETINTERIORPOWERPLUG\">ổ cắm điện</link>.\n\nHao phí dần theo thời gian.\n\nPhải xây dựng trên Bệ phóng tên lửa trước."
msgstr "Tích trữ <link=\"POWER\">điện</link> từ động cơ tên lửa hoặc từ <link=\"LAUNCHPAD\">bệ phóng</link>.\n\nĐiện được tích trữ có thể dùng trong khoang hành khách thông qua <link=\"ROCKETINTERIORPOWERPLUG\">ổ cắm điện</link>.\n\nHao phí dần theo thời gian.\n\nPhải xây dựng trên Bệ phóng tên lửa trước."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SMOLBATTERYMODULE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SMOLBATTERYMODULE.NAME"
msgid "<link=\"RTBSMOLBATTERYMODULE\">Small Battery Module</link>"
msgstr "<link=\"RTBSMOLBATTERYMODULE\">Khoang Pin Nhỏ</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SOLARPANELMODULE_WIDE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SOLARPANELMODULE_WIDE.DESC"
msgid "Thu thập năng lượng mặt trời trước khi cất cánh và trong chuyến bay.\nThat small module looked so off on wide rockets!"
msgstr "Thu thập năng lượng mặt trời trước khi cất cánh và trong chuyến bay.\nCái khoang nhỏ đó trông thật lạc lõng trên các tên lửa rộng!"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SOLARPANELMODULE_WIDE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SOLARPANELMODULE_WIDE.EFFECT"
msgid "Chuyển hóa <link=\"LIGHT\">Ánh sáng mặt trời</link> thành<link=\"POWER\">Điện năng</link> cung cấp cho tên lửa.\n\nCần xây đựng <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> trước.\n\nPhải được tiếp xúc với không gian."
msgstr "Chuyển hóa <link=\"LIGHT\">Ánh sáng mặt trời</link> thành <link=\"POWER\">Điện năng</link> cung cấp cho tên lửa.\n\nCần xây dựng <link=\"LAUNCHPAD\">Bệ phóng tên lửa</link> trước.\n\nPhải được tiếp xúc với không gian."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SOLARPANELMODULE_WIDE.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SOLARPANELMODULE_WIDE.NAME"
msgid "<link=\"RTBSOLARPANELMODULEWIDE\">Wide Khoang pin mặt trời</link>"
msgstr "<link=\"RTBSOLARPANELMODULEWIDE\">Khoang Pin Mặt Trời Rộng</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR.DESC"
msgid "Connecting with another (rocket) has never been easier."
msgstr "Kết nối với tên lửa khác chưa bao giờ dễ đến vậy."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR.EFFECT"
msgid "Enables docking with rockets to dock\n\nAllows loading and unloading docked rockets\n\nRockets require a docking component to dock.\n\nAssigning a duplicant forces it to use the docking bridge."
msgstr "Cho phép kết nối với tên lửa để cập bến\n\nCho phép nạp và dỡ hàng tên lửa đã kết nối\n\nTên lửa cần bộ phận kết nối để kết nối.\n\nChỉ định Đệ sẽ buộc nó sử dụng cầu kết nối."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR.NAME
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR.NAME"
msgid "<link=\"RTBSPACESTATIONDOCKINGDOOR\">[WIP] Orbital Docking Port</link>"
msgstr "<link=\"RTBSPACESTATIONDOCKINGDOOR\">[ĐANG PHÁT TRIỂN] Cổng Kết Nối Quỹ Đạo</link>"

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR_INDESTRUCTIBLE.DESC
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR_INDESTRUCTIBLE.DESC"
msgid "Connecting with another (rocket) has never been easier."
msgstr "Kết nối với tên lửa khác chưa bao giờ dễ đến vậy."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR_INDESTRUCTIBLE.EFFECT
msgctxt "Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR_INDESTRUCTIBLE.EFFECT"
msgid "Enables docking with rockets to dock\n\nAllows loading and unloading docked rockets\n\nRockets require a docking component to dock.\n\nAssigning a duplicant forces it to use the docking bridge."
msgstr "Cho phép kết nối với tên lửa để cập bến\n\nCho phép nạp và dỡ hàng tên lửa đã kết nối\n\nTên lửa cần bộ phận kết nối để kết nối.\n\nChỉ định Đệ sẽ buộc nó sử dụng cầu kết nối."

#. Rockets_TinyYetBig.STRINGS.BUILDINGS.PREFABS.RTB_SPACESTATIONDOCKINGDOOR_INDESTRUCTIBLE.NAME
